# Vision / Test Case / Appium agent providers: openai | mock
VISION_AGENT_PROVIDER=openai
TESTCASE_AGENT_PROVIDER=openai
APPIUM_AGENT_PROVIDER=openai

# OpenAI-compatible LLM connection - works with OpenAI directly or any
# OpenAI-compatible gateway (e.g. an internal company LLM proxy).
# Ask your team lead for the real values. Never commit your filled-in .env.
OPENAI_API_KEY=your_api_key_here
OPENAI_API_BASE=your_gateway_base_url_here
OPENAI_MODEL=your_model_name_here

# To run fully offline with no LLM at all, set all three providers above to: mock

# Step 3 (Appium script generation/execution) - Android only for now
MOBILE_PLATFORM=android
APPIUM_SERVER_URL=http://127.0.0.1:4723
ANDROID_APP_PATH=demo_mobile_apps/mda-2.2.0-25.apk
